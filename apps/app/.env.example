# =============================================================================
# Neptlium — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit a file containing real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — public (exposed to the browser)
# Found in: Supabase Dashboard > Project Settings > API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New Supabase publishable key (replaces the old NEXT_PUBLIC_SUPABASE_ANON_KEY JWT format)
# Found in: Supabase Dashboard > Project Settings > API > Project API keys > publishable
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# -----------------------------------------------------------------------------
# Supabase — private (server only)
# NEVER expose this to the browser or include it in any client bundle.
# Found in: Supabase Dashboard > Project Settings > API > service_role key
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Application origin
# Used to build absolute redirect URLs for Supabase email links
# (emailRedirectTo for signup confirmation, password recovery, etc.)
#
# Local development:  http://localhost:3001
# Vercel preview:     https://your-deployment.vercel.app
# Production:         https://app.neptlium.com
#
# In Vercel, set this to your canonical production domain.
# In Supabase Dashboard > Authentication > URL Configuration, add:
#   - Site URL:          https://app.neptlium.com
#   - Redirect URLs:     https://app.neptlium.com/auth/confirm
#                        https://app.neptlium.com/update-password
#                        http://localhost:3001/auth/confirm        (local dev)
#                        http://localhost:3001/update-password     (local dev)
#                        https://*.vercel.app/auth/confirm         (previews)
#                        https://*.vercel.app/update-password      (previews)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Resend — transactional email (server only)
# Found in: resend.com/api-keys
# Used for: sending emails via the Resend API
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-api-key-here

# -----------------------------------------------------------------------------
# Runtime environment (optional)
# -----------------------------------------------------------------------------
NODE_ENV=development
