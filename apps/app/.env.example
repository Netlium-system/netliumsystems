# -----------------------------------------------------------------------------
# Supabase (Public - exposed to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Supabase (Private - server only)
# Never expose this key to the browser or commit a real value.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
NODE_ENV=development

# Public origin used to build absolute redirect URLs (e.g. Supabase's
# emailRedirectTo for the signup confirmation link). Falls back to the
# request's forwarded host headers when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
