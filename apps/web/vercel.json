{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",

  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && npx turbo run build --filter=@neptlium/web...",
  "outputDirectory": ".next",

  "ignoreCommand": "cd ../.. && npx turbo-ignore @neptlium/web",

  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.neptlium.com" }],
      "destination": "https://neptlium.com/:path*",
      "permanent": true
    },
    {
      "source": "/app/:path*",
      "destination": "https://app.neptlium.com/:path*",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://app.neptlium.com/login",
      "permanent": false
    },
    {
      "source": "/sign-up",
      "destination": "https://app.neptlium.com/sign-up",
      "permanent": false
    },
    {
      "source": "/sign-in",
      "destination": "https://app.neptlium.com/login",
      "permanent": false
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
