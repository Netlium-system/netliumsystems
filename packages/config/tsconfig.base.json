{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "importsNotUsedAsValues": "error",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "@netlium/config": ["./"],
      "@netlium/config/*": ["./*"]
    }
  }
}
