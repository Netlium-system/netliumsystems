{
  "name": "@netlium/config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Netlium Systems shared engineering configuration package.",
  "files": [
    "tsconfig.base.json",
    "tsconfig.json",
    "eslint.config.mjs",
    "prettier.config.mjs",
    "tailwind.config.ts",
    "README.md"
  ],
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint.config.mjs": "./eslint.config.mjs",
    "./prettier.config.mjs": "./prettier.config.mjs",
    "./tailwind.config.ts": "./tailwind.config.ts"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "lint": "pnpm exec eslint . --max-warnings 0",
    "check-types": "pnpm exec tsc -p tsconfig.json --noEmit",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check ."
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "eslint-plugin-react": "^8.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "eslint-plugin-jsx-a11y": "^7.0.0",
    "eslint-plugin-import": "^2.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.0.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2"
  }
}
